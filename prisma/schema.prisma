generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String                  @id @default(uuid()) @db.Uuid
  name         String                  @db.VarChar(100)
  domain       String?                 @db.VarChar
  logoUrl      String?                 @map("logo_url") @db.VarChar
  primaryColor String?                 @map("primary_color") @db.VarChar
  createdAt    DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  users        User[]
  chatAudits   ChatAudit[]
  configs      FacebookCskhConfig[]
  sessions     FacebookOAuthSession[]
  jobs         CskhJobRun[]
  monitors     CskhMonitorItem[]
  convs        CskhInboxConversation[]
  messages     CskhInboxMessage[]

  @@map("tenants")
}

model User {
  id          Int         @id @default(autoincrement())
  fullName    String      @map("full_name") @db.VarChar(100)
  email       String      @unique @db.VarChar(100)
  password    String      @db.VarChar
  role        String      @default("user") @db.VarChar
  isActive    Boolean     @default(true) @map("is_active")
  avatarUrl   String?     @map("avatar_url") @db.VarChar
  phoneNumber String?     @map("phone_number") @db.VarChar(20)
  tenantId    String?     @map("tenant_id") @db.Uuid
  tenant      Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  chatAudits  ChatAudit[]

  @@map("users")
}

model ChatAudit {
  id           String   @id @default(uuid()) @db.Uuid
  userId       Int?     @map("user_id")
  agentName    String?  @map("agent_name") @db.VarChar
  customerName String?  @map("customer_name") @db.VarChar
  channel      String?  @db.VarChar
  score        Int      @default(0)
  feedback     String?  @db.Text
  transcript   Json?
  metadata     Json?
  tenantId     String?  @map("tenant_id") @db.Uuid
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("chat_audits")
}

model FacebookCskhConfig {
  id              String   @id @default(uuid()) @db.Uuid
  pageId          String   @unique @map("page_id")
  pageName        String?  @map("page_name") @db.VarChar
  pageAccessToken String   @map("page_access_token") @db.Text
  enabled         Boolean  @default(true)
  metadata        Json?
  tenantId        String?  @map("tenant_id") @db.Uuid
  tenant          Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("facebook_cskh_configs")
}

model FacebookOAuthSession {
  id              String    @id @default(uuid()) @db.Uuid
  fbUserId        String    @unique @map("fb_user_id")
  fbUserName      String?   @map("fb_user_name") @db.VarChar
  userAccessToken String    @map("user_access_token") @db.Text
  tokenExpiresAt  DateTime? @map("token_expires_at") @db.Timestamptz(6)
  metadata        Json?
  tenantId        String?   @map("tenant_id") @db.Uuid
  tenant          Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("facebook_oauth_sessions")
}

model CskhJobRun {
  id           String            @id @default(uuid()) @db.Uuid
  type         String
  status       String            @default("running")
  summary      Json?
  error        String?           @db.Text
  tenantId     String?           @map("tenant_id") @db.Uuid
  tenant       Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  startedAt    DateTime          @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt   DateTime?         @map("finished_at") @db.Timestamptz(6)
  monitorItems CskhMonitorItem[]

  @@map("cskh_job_runs")
}

model CskhMonitorItem {
  id             String     @id @default(uuid()) @db.Uuid
  jobRunId       String     @map("job_run_id") @db.Uuid
  pageId         String     @map("page_id")
  pageName       String?    @map("page_name") @db.VarChar
  conversationId String     @map("conversation_id")
  customerName   String?    @map("customer_name") @db.VarChar
  lastMessage    String?    @map("last_message") @db.Text
  needsReply     Boolean    @default(true) @map("needs_reply")
  tenantId       String?    @map("tenant_id") @db.Uuid
  tenant         Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedAt      DateTime?  @map("updated_at") @db.Timestamptz(6)
  jobRun         CskhJobRun @relation(fields: [jobRunId], references: [id], onDelete: Cascade)

  @@map("cskh_monitor_items")
}

model CskhInboxConversation {
  id                 String             @id @default(uuid()) @db.Uuid
  pageId             String             @map("page_id")
  pageName           String?            @map("page_name") @db.VarChar
  fbConversationId   String?            @map("fb_conversation_id") @db.VarChar
  participantPsid    String             @map("participant_psid")
  customerName       String?            @map("customer_name") @db.VarChar
  customerPictureUrl String?            @map("customer_picture_url") @db.VarChar
  lastMessage        String?            @map("last_message") @db.Text
  lastMessageAt      DateTime?          @map("last_message_at") @db.Timestamptz(6)
  unreadCount        Int                @default(0) @map("unread_count")
  fromAd             Boolean            @default(false) @map("from_ad")
  adId               String?            @map("ad_id") @db.VarChar
  adTitle            String?            @map("ad_title") @db.VarChar
  referralSource     String?            @map("referral_source") @db.VarChar
  referralAt         DateTime?          @map("referral_at") @db.Timestamptz(6)
  tenantId           String?            @map("tenant_id") @db.Uuid
  tenant             Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  messages           CskhInboxMessage[]

  @@unique([pageId, participantPsid])
  @@map("cskh_inbox_conversations")
}

model CskhInboxMessage {
  id             String                @id @default(uuid()) @db.Uuid
  conversationId String                @map("conversation_id") @db.Uuid
  fbMessageId    String?               @unique @map("fb_message_id") @db.VarChar
  direction      String
  senderType     String                @map("sender_type")
  text           String                @db.Text
  messageType    String                @default("text") @map("message_type")
  attachmentUrl  String?               @map("attachment_url") @db.Text
  tenantId       String?               @map("tenant_id") @db.Uuid
  tenant         Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sentAt         DateTime              @default(now()) @map("sent_at") @db.Timestamptz(6)
  status         String                @default("sent")
  conversation   CskhInboxConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("cskh_inbox_messages")
}
